/* pages/index/index.wxss v5.0 - 专业交易系统 */
/* 深空蓝黑主题，专业交易界面 */

/* ─────────── 全局基础 ─────────── */
page {
  background: #0a0e17;
  color: #e2e8f0;
  font-size: 28rpx;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  -webkit-font-smoothing: antialiased;
  line-height: 1.5;
}

/* ─────────── 顶部栏 ─────────── */
.top-header {
  background: linear-gradient(180deg, #0d1117 0%, #090d14 100%);
  border-bottom: 1rpx solid rgba(59, 130, 246, 0.2);
  padding: 20rpx 24rpx 16rpx;
}

.top-header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.top-logo {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.logo-icon {
  font-size: 48rpx;
  font-weight: 900;
  color: #fbbf24;
  text-shadow: 0 0 20rpx rgba(251, 191, 36, 0.5);
}

.logo-badge {
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  letter-spacing: 1rpx;
}

.top-title {
  flex: 1;
  text-align: center;
}

.title-main {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(90deg, #60a5fa, #3b82f6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 1rpx;
}

.title-sub {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.top-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: rgba(59, 130, 246, 0.1);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.action-btn:active {
  background: rgba(59, 130, 246, 0.2);
  transform: scale(0.95);
}

.action-btn .icon {
  font-size: 28rpx;
}

/* 周期切换标签 */
.period-tabs {
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
  -webkit-overflow-scrolling: touch;
}

.period-tab {
  flex: 1;
  min-width: 160rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: rgba(30, 41, 59, 0.5);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  text-align: center;
  transition: all 0.2s;
  position: relative;
}

.period-tab.active {
  background: rgba(59, 130, 246, 0.2);
  border-color: #3b82f6;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.period-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #e2e8f0;
}

.period-tab.active .period-label {
  color: #60a5fa;
}

.period-indicator {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 4rpx;
  background: #3b82f6;
  border-radius: 2rpx;
}

/* ─────────── 价格信息 ─────────── */
.price-section {
  background: rgba(15, 23, 42, 0.8);
  margin: 20rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.15);
}

.price-main {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.price-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #f8fafc;
  letter-spacing: 1rpx;
}

.price-change {
  font-size: 32rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.price-change.positive {
  color: #10b981;
  background: rgba(16, 185, 129, 0.1);
}

.price-change.negative {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
}

.price-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.meta-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.meta-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #e2e8f0;
}

/* ─────────── 趋势状态 ─────────── */
.trend-section {
  margin: 20rpx 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.trend-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.trend-icon {
  font-size: 32rpx;
}

.trend-label {
  font-size: 28rpx;
  font-weight: 700;
  flex: 1;
}

.trend-ma {
  display: flex;
  gap: 12rpx;
  font-size: 24rpx;
}

.ma-label {
  color: #94a3b8;
}

.ma-value {
  color: #e2e8f0;
  font-weight: 600;
}

.trend-position {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
}

.position-label {
  color: #94a3b8;
  font-size: 24rpx;
}

.position-value {
  font-size: 26rpx;
  font-weight: 700;
}

.position-value.positive {
  color: #10b981;
}

.position-value.negative {
  color: #ef4444;
}

/* ─────────── 核心信号卡片 ─────────── */
.signal-card {
  margin: 20rpx 24rpx;
  background: rgba(15, 23, 42, 0.9);
  border-radius: 20rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  overflow: hidden;
}

.signal-header {
  padding: 24rpx;
  background: rgba(30, 41, 59, 0.5);
  border-bottom: 1rpx solid rgba(59, 130, 246, 0.1);
}

.signal-direction {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.direction-icon {
  font-size: 36rpx;
}

.direction-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #f8fafc;
}

.signal-strength {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.strength-stars {
  font-size: 28rpx;
  color: #fbbf24;
  letter-spacing: 2rpx;
}

.strength-label {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 多周期共振 */
.resonance-section {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #e2e8f0;
  margin-bottom: 16rpx;
}

.resonance-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.resonance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  background: rgba(30, 41, 59, 0.5);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  transition: all 0.2s;
}

.resonance-item.active {
  background: rgba(59, 130, 246, 0.15);
  border-color: #3b82f6;
}

.resonance-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.resonance-label {
  font-size: 22rpx;
  color: #e2e8f0;
}

.resonance-meta {
  display: flex;
  gap: 24rpx;
}

.resonance-meta .meta-item {
  flex: 1;
}

.resonance-meta .meta-value.extreme {
  color: #ef4444;
  font-weight: 700;
}

.resonance-meta .meta-value.high {
  color: #10b981;
  font-weight: 700;
}

/* 条件验证 */
.conditions-section {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.conditions-progress {
  font-size: 24rpx;
  font-weight: 700;
  color: #3b82f6;
  background: rgba(59, 130, 246, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.conditions-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.condition-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: rgba(30, 41, 59, 0.5);
}

.condition-item.ok {
  border-left: 4rpx solid #10b981;
}

.condition-item.not-ok {
  border-left: 4rpx solid #ef4444;
  opacity: 0.7;
}

.condition-icon {
  font-size: 24rpx;
  font-weight: 700;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.condition-item.ok .condition-icon {
  background: rgba(16, 185, 129, 0.2);
  color: #10b981;
}

.condition-item.not-ok .condition-icon {
  background: rgba(239, 68, 68, 0.2);
  color: #ef4444;
}

.condition-label {
  flex: 1;
  font-weight: 600;
  color: #e2e8f0;
}

.condition-tip {
  font-size: 22rpx;
  color: #94a3b8;
  text-align: right;
}

/* 交易计划 */
.trade-plan {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.plan-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.plan-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  background: rgba(30, 41, 59, 0.5);
  border-radius: 12rpx;
}

.plan-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.plan-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #e2e8f0;
}

.plan-value.stop-loss {
  color: #ef4444;
}

.take-profits {
  background: rgba(30, 41, 59, 0.5);
  border-radius: 12rpx;
  padding: 16rpx;
}

.tp-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.tp-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.tp-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx;
  background: rgba(15, 23, 42, 0.8);
  border-radius: 8rpx;
}

.tp-level {
  font-size: 20rpx;
  color: #94a3b8;
  font-weight: 600;
}

.tp-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #10b981;
}

/* 仓位建议 */
.position-section {
  padding: 20rpx 24rpx;
}

.position-rating {
  font-size: 24rpx;
  color: #fbbf24;
  letter-spacing: 2rpx;
}

.position-details {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.position-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 12rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

.pos-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.pos-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #e2e8f0;
}

/* ─────────── 无信号状态 ─────────── */
.no-signal-card {
  margin: 20rpx 24rpx;
  background: rgba(15, 23, 42, 0.9);
  border-radius: 20rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  padding: 60rpx 40rpx;
  text-align: center;
}

.no-signal-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.no-signal-icon {
  font-size: 64rpx;
  opacity: 0.5;
}

.no-signal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e2e8f0;
}

.no-signal-desc {
  font-size: 24rpx;
  color: #94a3b8;
  max-width: 400rpx;
  line-height: 1.4;
}

.no-signal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.no-signal-actions .action-btn {
  padding: 16rpx 32rpx;
  background: rgba(59, 130, 246, 0.1);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #3b82f6;
  transition: all 0.2s;
}

.no-signal-actions .action-btn:active {
  background: rgba(59, 130, 246, 0.2);
}

/* ─────────── 技术指标矩阵 ─────────── */
.indicators-section {
  margin: 20rpx 24rpx;
  background: rgba(15, 23, 42, 0.9);
  border-radius: 20rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  padding: 24rpx;
}

.indicators-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.indicator-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  background: rgba(30, 41, 59, 0.5);
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}

.indicator-item.bullish {
  border-left: 4rpx solid #10b981;
}

.indicator-item.bearish {
  border-left: 4rpx solid #ef4444;
}

.indicator-item.oversold,
.indicator-item.overbought {
  border-left: 4rpx solid #fbbf24;
}

.indicator-item.low {
  border-left: 4rpx solid #3b82f6;
}

.indicator-item.high {
  border-left: 4rpx solid #8b5cf6;
}

.indicator-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #e2e8f0;
}

.indicator-value {
  font-size: 28rpx;
  font-weight: 800;
  color: #f8fafc;
}

.indicator-hint {
  font-size: 20rpx;
  color: #94a3b8;
}

.indicator-status {
  position: absolute;
  top: 0;
  right: 0;
  width: 8rpx;
  height: 100%;
}

.indicator-status.bullish {
  background: #10b981;
}

.indicator-status.bearish {
  background: #ef4444;
}

.indicator-status.oversold,
.indicator-status.overbought {
  background: #fbbf24;
}

.indicator-status.neutral {
  background: #64748b;
}

/* ─────────── 错误提示 ─────────── */
.error-section {
  margin: 20rpx 24rpx;
  padding: 40rpx 24rpx;
  background: rgba(239, 68, 68, 0.1);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  border-radius: 16rpx;
  text-align: center;
}

.error-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  display: block;
}

.error-text {
  font-size: 24rpx;
  color: #fca5a5;
  margin-bottom: 20rpx;
}

.error-action {
  display: inline-block;
  padding: 12rpx 32rpx;
  background: rgba(239, 68, 68, 0.2);
  border: 1rpx solid rgba(239, 68, 68, 0.4);
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fca5a5;
  transition: all 0.2s;
}

.error-action:active {
  background: rgba(239, 68, 68, 0.3);
}

/* ─────────── 加载状态 ─────────── */
.loading-section {
  margin: 40rpx 24rpx;
  padding: 60rpx 24rpx;
  text-align: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid rgba(59, 130, 246, 0.2);
  border-top: 8rpx solid #3b82f6;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ─────────── 底部操作栏 ─────────── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(15, 23, 42, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(59, 130, 246, 0.2);
  padding: 16rpx 24rpx;
  z-index: 100;
}

.bottom-actions {
  display: flex;
  justify-content: space-around;
}

.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.bottom-btn:active {
  background: rgba(59, 130, 246, 0.1);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 600;
}

/* ─────────── 响应式调整 ─────────── */
@media (max-width: 375px) {
  .price-value {
    font-size: 48rpx;
  }
  
  .period-tab {
    min-width: 140rpx;
  }
  
  .indicators-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* 滚动条美化 */
::-webkit-scrollbar {
  width: 8rpx;
  height: 8rpx;
}

::-webkit-scrollbar-track {
  background: rgba(30, 41, 59, 0.5);
  border-radius: 4rpx;
}

::-webkit-scrollbar-thumb {
  background: rgba(59, 130, 246, 0.5);
  border-radius: 4rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(59, 130, 246, 0.7);
}